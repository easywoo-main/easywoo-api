// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String  @id @default(uuid())
  email            String  @unique
  name             String
  password         String?
  isVerified       Boolean @default(false)
  hasQuizCompleted Boolean @default(false)

  googleUserId String? @unique
  appleUserId  String? @unique

  answers    Answer[]
  googleUser GoogleUser? @relation(fields: [googleUserId], references: [id])
  appleUser  AppleUser?  @relation(fields: [appleUserId], references: [id])
}

model GoogleUser {
  id              String  @id @default(uuid())
  googleAccountId String  @unique
  email           String  @unique
  firstName       String
  lastName        String
  picture         String?
  emailVerified   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User?
}

model AppleUser {
  id            String  @id @default(uuid())
  appleId       String  @unique
  email         String  @unique
  firstName     String
  lastName      String
  photo         String?
  emailVerified Boolean @default(false)
  userId        String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User?
}

enum QuestionsType {
  single
  multiple
  slider
}

model Question {
  id       String        @id @default(uuid())
  step     Int
  question String
  type     QuestionsType
  name     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  answers Answer[]

  @@unique([question])
  @@unique([name])
}

model Sentence {
  id       String @id @default(uuid())
  sentence String

  condition Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sentence])
}

model Answer {
  id         String @id @default(uuid())
  answer     String
  name       String
  questionId String

  evaluation Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  question Question @relation(fields: [questionId], references: [id])
  users    User[]

  @@unique([answer, questionId])
  @@unique([name, questionId])
}
