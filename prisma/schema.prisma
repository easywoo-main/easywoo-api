// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String  @id @default(uuid())
  email            String  @unique
  name             String
  password         String?
  isVerified       Boolean @default(false)
  hasQuizCompleted Boolean @default(false)

  googleUserId String? @unique
  appleUserId  String? @unique

  answers    Answer[]
  googleUser GoogleUser? @relation(fields: [googleUserId], references: [id])
  appleUser  AppleUser?  @relation(fields: [appleUserId], references: [id])
  courses    Course[]
}

model GoogleUser {
  id              String  @id @default(uuid())
  googleAccountId String  @unique
  email           String  @unique
  firstName       String
  lastName        String
  picture         String?
  emailVerified   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User?
}

model AppleUser {
  id            String  @id @default(uuid())
  appleId       String  @unique
  email         String  @unique
  firstName     String
  lastName      String
  photo         String?
  emailVerified Boolean @default(false)
  userId        String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User?
}

enum QuestionsType {
  SINGLE
  MULTIPLE
  SLIDER
}

model Question {
  id       String        @id @default(uuid())
  step     Int
  question String
  name     String
  type     QuestionsType

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  answers Answer[]

  @@unique([question])
  @@unique([name])
}

model Sentence {
  id       String       @id @default(uuid())
  sentence String
  type     SentenceType

  condition      Json
  dbFindManyArgs Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sentence])
}

enum SentenceType {
  INTRO
  USER_INTRODUCTION
  TARGET_AUDIENCE
  RELATIONSHIP_GOALS
  FINAL_CONSIDERATIONS
  EMOTIONAL_BAGGAGE
  DEEP_DIVE
  EASY_SOCIAL
  CARE_PLAN
}

model Answer {
  id         String @id @default(uuid())
  answer     String
  name       String
  questionId String

  evaluation Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  question Question @relation(fields: [questionId], references: [id])
  users    User[]

  @@unique([answer, questionId])
  @@unique([name, questionId])
}

model Course {
  id      String       @id @default(uuid())
  title   String
  type    CourseType
  status  CourseStatus
  content String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tags Tag[]

  users User[]
}

enum CourseType {
  JOB_LISTING
}

enum CourseStatus {
  PUBLISH
}

model Tag {
  id   String @id @default(uuid())
  name String
  slug String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courses Course[]

  @@unique([name])
  @@unique([slug])
}

enum MessageType {
  TEXT

  //QUESTION
  QUESTION_MULTIPLE
  QUESTION_SINGLE
  QUESTION_CHELENGES
}

model ChatMessage {
  id    String      @id @default(uuid())
  name  String?
  type  MessageType
  files String[]

  nextMessageId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nextMessage  ChatMessage?  @relation("MessageToNext", fields: [nextMessageId], references: [id])
  prevMessages ChatMessage[] @relation("MessageToNext")

  nextChoices MessageChoice[] @relation("MessageToPrev")
  prevChoices MessageChoice[] @relation("MessageToNext")
  Chat        Chat?
}

enum ChoiceType {
  SINGLE
  MULTIPLE_SLIDER
}

model MessageChoice {
  id      String     @id @default(uuid())
  name    String
  type    ChoiceType
  timeout Int        @default(0)

  prevMessageId String
  nextMessageId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nextMessage ChatMessage? @relation("MessageToNext", fields: [nextMessageId], references: [id])
  prevMessage ChatMessage  @relation("MessageToPrev", fields: [prevMessageId], references: [id])
}

model Chat {
  id   String @id @default(uuid())
  name String

  startMessageId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  startMessage ChatMessage? @relation(fields: [startMessageId], references: [id])
}
